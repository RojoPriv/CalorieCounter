<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CalorieCounter.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CalorieCounter.Pages"
    Title="CalorieCounter">
    <TabBar>

        <ShellContent
            Icon= "fork_knife.png"
            ContentTemplate="{DataTemplate local:FoodInfo}"
            Route="FoodInfo" />

        <ShellContent
            Icon="home.png"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
      
       </TabBar>

</Shell>
