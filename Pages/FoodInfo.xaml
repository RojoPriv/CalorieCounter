<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalorieCounter.Pages.FoodInfo"
             Title="FoodInfo"
             BackgroundColor="White">
    <VerticalStackLayout>

        <Entry x:Name="foodEntryField" Placeholder="Food" />
        <Entry x:Name="CalorieEntryField" Placeholder="CaloriePerGram" />
        <Button x:Name="addButton" Text="Add" Clicked="addButton_Clicked" BackgroundColor="Green" />
        
    </VerticalStackLayout>
</ContentPage>