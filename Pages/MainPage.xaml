<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model = "clr-namespace:CalorieCounter.Db"
             x:Class="CalorieCounter.Pages.MainPage">


    <VerticalStackLayout>
       <Label x:Name="dateLabel" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,20,0,10"/>
        <Grid RowDefinitions="Auto,Auto,Auto,*">

            <Entry x:Name="foodEntryField" x:DataType="model:DailyTrackerDbModel" Placeholder="Food" Grid.Row="0"/>
            <Entry x:Name="gramEntryField" x:DataType="model:DailyTrackerDbModel" Placeholder="Gram" Grid.Row="1"/>
            <Button x:Name="addButton" Text="Add" Clicked="addButton_Clicked" 
             HorizontalOptions="Center"
             Margin="20" WidthRequest="150"
             BackgroundColor= "Black" Grid.Row="2"/>

            <CollectionView x:Name="CalorieInfoView" SelectionMode="Single" SelectionChanged="CalorieInfoView_SelectionChanged" Margin="10" Grid.Row="3" >
                <CollectionView.Header>
                    <Grid Padding="5" BackgroundColor="#EEE">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label Text="Food" FontAttributes="Bold" />
                        <Label Text="Gram" Grid.Column="1" FontAttributes="Bold" />
                        <Label Text="Calories" Grid.Column="2" FontAttributes="Bold" />
                    </Grid>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:DailyTrackerDbModel">
                        <Grid Padding="5" BackgroundColor="White">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Text="{Binding Food}" />
                            <Label Text="{Binding Grams}" Grid.Column="1" />
                            <Label Text="{Binding Calories}" Grid.Column="2" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

    </VerticalStackLayout>
    

</ContentPage>
